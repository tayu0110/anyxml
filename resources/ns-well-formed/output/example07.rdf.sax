startElement(http://www.w3.org/1999/02/22-rdf-syntax-ns#, RDF, rdf:RDF, {http://www.w3.org/2000/xmlns/}rdf='http://www.w3.org/1999/02/22-rdf-syntax-ns#', {http://www.w3.org/2000/xmlns/}dc='http://purl.org/dc/elements/1.1/', {http://www.w3.org/2000/xmlns/}ex='http://example.org/stuff/1.0/')
characters(
  )
