characters(
    )
startElement(http://example.org/stuff/1.0/, editor, ex:editor)
characters(
      )
startElement(http://www.w3.org/1999/02/22-rdf-syntax-ns#, Description, rdf:Description, {http://example.org/stuff/1.0/}fullName='Dave Beckett')
characters(
	)
startElement(http://example.org/stuff/1.0/, homePage, ex:homePage, {http://www.w3.org/1999/02/22-rdf-syntax-ns#}resource='http://purl.org/net/dajobe/')
endElement(http://example.org/stuff/1.0/, homePage, ex:homePage)
characters(
      )
endElement(http://www.w3.org/1999/02/22-rdf-syntax-ns#, Description, rdf:Description)
characters(
    )
endElement(http://example.org/stuff/1.0/, editor, ex:editor)
characters(
